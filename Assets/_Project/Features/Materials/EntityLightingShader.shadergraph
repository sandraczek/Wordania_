{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "d35df3d63c3c46edb7fd20c56f28d026",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "CalculateDynamicLights (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": -1236.5,
            "y": -51.00009536743164,
            "width": 291.0,
            "height": 93.99999237060547
        }
    },
    "m_Slots": [
        {
            "m_Id": "fab0efdc8c0a4018b468bd75d6c3b6b2"
        },
        {
            "m_Id": "f590ddae9437401e8a8dd177420f0abe"
        }
    ],
    "synonyms": [
        "code",
        "HLSL"
    ],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "CalculateDynamicLights",
    "m_FunctionSource": "fd1ba0835ad2749eeb4580eb12943011",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "uniform float4 _DynamicLightData[32]; \nuniform float4 _DynamicLightColors[32];\nuniform int _DynamicLightCount;\n\nfloat3 totalDynamicLight = float3(0, 0, 0);\n\nfor(int i = 0; i < _DynamicLightCount; i++) \n{\n    float2 lightPos = _DynamicLightData[i].xy;\n    float radius = _DynamicLightData[i].z;\n    float intensity = _DynamicLightData[i].w;\n    float3 color = _DynamicLightColors[i].rgb;\n\n    float dist = distance(WorldPos, lightPos);\n    \n    float atten = saturate(1.0 - (dist / radius));\n    \n    atten = atten * atten; \n\n    totalDynamicLight += color * atten * intensity;\n}\n\nAddedLight = totalDynamicLight;"
}

